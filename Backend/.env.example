# ─── Lensly backend environment ───────────────────────────────
# Copy to `.env` and fill in real values (never commit .env).

# Supabase — Project Settings → API
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY   # server-only secret, bypasses RLS

# Auth (custom JWT)
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Server
PORT=3000
# Comma-separated allowed origins for CORS, or * in development.
# In production set this to your Cloudflare Pages domain.
CORS_ORIGIN=*
